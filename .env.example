# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google Gemini API Key (получить на https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Модель Gemini (опционально, по умолчанию gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Максимальное количество сообщений в истории диалога (опционально, по умолчанию 20)
MAX_HISTORY_LENGTH=20
